# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# Site
NEXT_PUBLIC_SITE_URL=https://espaciointeriorec.com  # use http://localhost:3000 for local dev

# Contact emails
CONTACT_EMAIL=contacto@espaciointeriorec.com
LEGAL_EMAIL=use@espaciointeriorec.com

# Pinterest (https://business.pinterest.com → Claim Website → HTML tag method)
PINTEREST_DOMAIN_VERIFY=

# Booking (optional — if using Calendly API)
# CALENDLY_API_TOKEN=your_token_here

# WhatsApp Business (click-to-chat — Ecuador country code, no + prefix)
NEXT_PUBLIC_WHATSAPP_NUMBER=593XXXXXXXXX

# Social media profile URLs (leave empty string to hide that platform's icon in footer)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/espaciointeriorec
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/espaciointeriorec
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/espaciointeriorec
NEXT_PUBLIC_PINTEREST_URL=https://pinterest.com/espaciointeriorec

# Facebook — App credentials (Settings → Basic in the Developer Portal)
# App ID is safe to expose; App Secret must never be made public
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=            # Used to verify signed data-deletion callbacks from Meta

# Facebook — Page credentials (Graph API Explorer → exchange for long-lived Page token)
# Needed for: embedding feed, posting from server
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Substack
# Publication subdomain — used server-side to fetch the RSS feed
SUBSTACK_PUBLICATION=espaciointeriorec       # results in https://espaciointeriorec.substack.com/feed
# Handle — used client-side for the subscribe button link (no @ prefix)
NEXT_PUBLIC_SUBSTACK_HANDLE=espaciointerior  # results in https://substack.com/@espaciointerior

# Substack → Facebook automation (cron)
# Secret header validated by POST /api/cron/substack-sync — must match EventBridge Connection value
# Generate with: openssl rand -base64 32
CRON_SECRET=

# DynamoDB dedup store — tracks which Substack posts have been auto-posted to Facebook
# Injected by Terraform; set manually here for local testing
DYNAMODB_TABLE_NAME=interior-espacio-substack-posts
DYNAMODB_ACCESS_KEY_ID=
DYNAMODB_SECRET_ACCESS_KEY=
