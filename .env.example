# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=contact@interiorespacio.com

# Pinterest (https://business.pinterest.com → Claim Website → HTML tag method)
PINTEREST_DOMAIN_VERIFY=

# Booking (optional — if using Calendly API)
# CALENDLY_API_TOKEN=your_token_here

# WhatsApp Business (click-to-chat — Ecuador country code, no + prefix)
NEXT_PUBLIC_WHATSAPP_NUMBER=593XXXXXXXXX

# Social media profile URLs (leave empty string to hide that platform's icon in footer)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/interiorespacio
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/interiorespacio
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/interiorespacio
NEXT_PUBLIC_PINTEREST_URL=https://pinterest.com/interiorespacio

# Facebook Graph API (https://developers.facebook.com → My Apps → Graph API Explorer)
# Needed for: posting from admin, embedding feed on site
# Get a long-lived Page Access Token so it doesn't expire
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Admin panel passphrase — protects /admin/* routes
ADMIN_SECRET=
